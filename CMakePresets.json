{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "qt-debug",
      "displayName": "Qt Debug with Ninja (portable)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-qt-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "$env{QTDIR};$env{Qt6_DIR};C:/msys64/ucrt64"
      }
    },
    {
      "name": "qt-mingw-debug",
      "displayName": "Qt MinGW Debug",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build-mingw-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "$env{QTDIR};$env{Qt6_DIR};C:/msys64/ucrt64"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug (VS 18 2026)",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build-msvc-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "$env{QTDIR};$env{Qt6_DIR};C:/msys64/ucrt64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-debug",
      "configurePreset": "qt-debug"
    },
    {
      "name": "qt-mingw-debug",
      "configurePreset": "qt-mingw-debug"
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug"
    }
  ]
}
